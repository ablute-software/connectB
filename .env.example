# --- Supabase (Phase: connect the real database) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Public app URL ---
# Canonical base for links generated FOR users (invite accept, Stripe
# checkout/portal return). Set to https://sherlockdeal.com after the domain is
# pointed at this Vercel project — the cutover is this env change + a redeploy.
# Falls back to the current Vercel URL when unset.
NEXT_PUBLIC_APP_URL=

# --- Email sending (Phase 5) ---
# Transactional mail (confirmations, invites, magic links) sends from the
# platform address via Resend — not from SENDER_EMAIL below.
RESEND_API_KEY=
# Verified Resend sender for transactional mail, e.g. "Sherlock Deal <noreply@sherlockdeal.com>".
# Optional: overrides the default display name + verified address (env-gated switch).
# Falls back to Resend's own onboarding@resend.dev sender (works without domain verification, low deliverability) if unset.
RESEND_FROM_EMAIL=

# DEPRECATED — single-tenant leftover, dev fallback for the ablute_ org ONLY.
# Investor outreach in the multi-tenant product must send from either the
# founder's own mailbox (per-user OAuth, IRM_SPEC §8d) or, at minimum, the
# org's own sender_email verified in Resend — never from a global env var.
# Do not read these for outreach sends in new code.
SENDER_EMAIL=nunomarujo@ablute.pt
BCC_EMAIL=investors@ablute.pt

# --- Billing (Stripe subscriptions, env-gated) ---
# Billing stays dark until ALL of these are set (stripeConfigured()); the Plans
# page then swaps its request-to-back-office CTA for real checkout + portal.
# Apply migration 0031 before setting these (the webhook writes orgs.stripe_*).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_GARAGE_MONTHLY=
STRIPE_PRICE_GARAGE_ANNUAL=
STRIPE_PRICE_MOTHERFUNDING_MONTHLY=
STRIPE_PRICE_MOTHERFUNDING_ANNUAL=

# --- AI Review (Phase 4, paid feature) ---
ANTHROPIC_API_KEY=
AI_REVIEW_MODEL=claude-sonnet-4-5

# --- Gmail OAuth pairing (IRM_SPEC §8d) ---
# Create an OAuth client (Web application) in Google Cloud Console; add
# https://<your-domain>/api/oauth/google/callback as an authorized redirect URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# 32-byte key, base64-encoded, for encrypting stored OAuth tokens at rest.
# Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# --- Investor self-claim (IRM_SPEC §5) ---
# Set to "true" once the Supabase LinkedIn OIDC provider is configured, to
# turn on the "Claim your profile" flow in the investor portal. Until then
# it shows an explanatory message instead. GDPR/RGPD requests do NOT need
# this — see /privacy-request, which works unconditionally.
NEXT_PUBLIC_LINKEDIN_OAUTH_ENABLED=
